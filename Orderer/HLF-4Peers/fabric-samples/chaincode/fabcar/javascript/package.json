{
    "name": "fabcar",
    "version": "1.0.0",
    "description": "FabCar contract implemented in JavaScript",
    "main": "index.js",
    "engines": {
        "node": ">=12",
        "npm": ">=6.9"
    },
    "scripts": {
        "lint": "eslint .",
        "pretest": "npm run lint",
        "test": "nyc mocha --recursive",
        "start": "fabric-chaincode-node start"
    },
    "engineStrict": true,
    "author": "Hyperledger",
    "license": "Apache-2.0",
    "dependencies": {
        "fabric-contract-api": "2.2.3",
        "fabric-shim": "2.2.3",
        "winston": "3.3.3",
        "winston-transport": "4.4.0",
        "logform": "2.2.0",
        "triple-beam": "1.3.0",
        "@dabh/diagnostics": "2.0.2",
        "color": "3.1.3",
        "color-string": "1.5.5",
        "color-convert": "1.9.3"
    },
    "devDependencies": {
        "chai": "^4.1.2",
        "eslint": "^4.19.1",
        "mocha": "^5.2.0",
        "nyc": "^14.1.1",
        "sinon": "^6.0.0",
        "sinon-chai": "^3.2.0"
    },
    "nyc": {
        "exclude": [
            "coverage/**",
            "test/**"
        ],
        "reporter": [
            "text-summary",
            "html"
        ],
        "all": true,
        "check-coverage": true,
        "statements": 100,
        "branches": 100,
        "functions": 100,
        "lines": 100
    }
}
